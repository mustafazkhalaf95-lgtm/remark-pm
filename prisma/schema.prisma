// ═══════════════════════════════════════════════════════════════
// Remark PM — Prisma Schema
// SQLite-backed persistence for the entire platform
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// ORGANIZATION LAYER
// ═══════════════════════════════════════════════════════════════

model Organization {
  id          String   @id @default(cuid())
  name        String
  nameAr      String   @default("")
  logo        String   @default("")
  timezone    String   @default("Asia/Baghdad")
  language    String   @default("ar")
  workWeek    String   @default("sun-thu") // sun-thu, mon-fri, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments Department[]
  settings    SystemSetting[]
  integrations IntegrationSetting[]
}

model Department {
  id             String   @id @default(cuid())
  name           String
  nameAr         String   @default("")
  slug           String   @unique
  description    String   @default("")
  descriptionAr  String   @default("")
  color          String   @default("#6366f1")
  icon           String   @default("📋")
  isActive       Boolean  @default(true)
  headUserId     String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  headUser       User?        @relation("DepartmentHead", fields: [headUserId], references: [id])
  userDepartments UserDepartment[]
  settings       DepartmentSetting[]

  @@index([organizationId])
  @@index([slug])
}

model DepartmentSetting {
  id           String   @id @default(cuid())
  departmentId String
  key          String
  value        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, key])
}

model SystemSetting {
  id             String   @id @default(cuid())
  organizationId String
  category       String   // general, notifications, security, branding
  key            String
  value          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
}

model IntegrationSetting {
  id             String   @id @default(cuid())
  organizationId String
  name           String   // notebooklm, openai, storage, webhook
  nameAr         String   @default("")
  provider       String   @default("")
  isEnabled      Boolean  @default(false)
  config         String   @default("{}") // JSON config
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
}

// ═══════════════════════════════════════════════════════════════
// IDENTITY & ACCESS LAYER
// ═══════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String   @default("")
  status       String   @default("active") // active, inactive, suspended
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile          UserProfile?
  userRoles        UserRole[]
  userDepartments  UserDepartment[]
  userClients      UserClient[]
  approvalAuthorities ApprovalAuthority[]
  headOfDepartments   Department[] @relation("DepartmentHead")
  auditLogs        AuditLog[]
  activities       ActivityLog[]
  comments         Comment[]
  approvalsMade    Approval[]
  notifications    Notification[]

  // User assignment relations
  marketingAssignments    MarketingTask[]    @relation("MarketingAssignee")
  creativeConceptRequests CreativeRequest[]  @relation("CreativeConceptWriter")
  creativeExecRequests    CreativeRequest[]  @relation("CreativeExecutor")
  productionAssignments   ProductionJob[]    @relation("ProductionAssignee")
  publishingReviews       PublishingItem[]   @relation("PublishingReviewer")

  // New module relations
  chatRoomMemberships ChatRoomMember[]
  chatMessages        ChatMessage[]     @relation("ChatMessageSender")
  timeEntries         TimeEntry[]       @relation("TimeEntries")
  leaveRequests       LeaveRequest[]    @relation("LeaveRequests")
  performanceReviews  PerformanceReview[] @relation("PerformanceReviews")
  reviewsConducted    PerformanceReview[] @relation("ReviewsConducted")
  wikiArticles        WikiArticle[]     @relation("WikiArticles")
  contactLogs         ContactLog[]      @relation("ContactLogs")
  calendarEvents      CalendarEvent[]   @relation("CalendarEvents")
  calendarAttendees   CalendarAttendee[] @relation("CalendarAttendees")

  @@index([email])
  @@index([status])
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  fullName        String
  fullNameAr      String   @default("")
  displayName     String   @default("")
  displayNameAr   String   @default("")
  avatar          String   @default("")
  phone           String   @default("")
  employeeCode    String   @default("")
  bio             String   @default("")
  bioAr           String   @default("")
  positionId      String?
  reportingToId   String?
  timezone        String   @default("Asia/Baghdad")
  language        String   @default("ar")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  position    Position? @relation(fields: [positionId], references: [id])
  reportingTo UserProfile? @relation("ReportsTo", fields: [reportingToId], references: [id])
  directReports UserProfile[] @relation("ReportsTo")

  @@index([positionId])
}

model Position {
  id          String   @id @default(cuid())
  title       String
  titleAr     String   @default("")
  category    String   @default("staff") // executive, client, marketing, creative, production, publishing, admin
  level       Int      @default(0) // 0=staff, 1=coordinator, 2=manager, 3=director, 4=c-suite
  description String   @default("")
  descriptionAr String @default("")
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profiles UserProfile[]

  @@index([category])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  nameAr      String   @default("")
  description String   @default("")
  descriptionAr String @default("")
  scope       String   @default("department") // platform, department, project
  isSystem    Boolean  @default(false) // cannot be deleted
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameAr      String   @default("")
  module      String   // settings, marketing, creative, production, publishing, clients, reports, approvals
  category    String   @default("action") // view, action, manage, approve, export
  description String   @default("")
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([module])
  @@index([category])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model UserDepartment {
  id           String @id @default(cuid())
  userId       String
  departmentId String
  isPrimary    Boolean @default(false)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
}

model UserClient {
  id       String @id @default(cuid())
  userId   String
  clientId String
  role     String @default("member") // lead, member, viewer
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
}

// ═══════════════════════════════════════════════════════════════
// APPROVAL LAYER
// ═══════════════════════════════════════════════════════════════

model ApprovalAuthority {
  id        String @id @default(cuid())
  userId    String
  scope     String // concept_preliminary, concept_final, export, publishing, unblock, revision
  scopeAr   String @default("")
  level     Int    @default(1) // 1=can approve, 2=must approve (required)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope])
  @@index([scope])
}

model ApprovalPolicy {
  id          String @id @default(cuid())
  name        String
  nameAr      String @default("")
  workflow    String // marketing_plan, creative_concept, production_review, final_delivery, publishing
  stage       String @default("")
  requiredRoleId String?
  requiredPositionId String?
  minApprovals Int    @default(1)
  isActive    Boolean @default(true)
  description String @default("")
  descriptionAr String @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workflow])
}

// ═══════════════════════════════════════════════════════════════
// BUSINESS LAYER
// ═══════════════════════════════════════════════════════════════

model Client {
  id          String   @id @default(cuid())
  name        String
  nameAr      String   @default("")
  sector      String   @default("")
  sectorAr    String   @default("")
  planType    String   @default("")
  budget      String   @default("")
  avatar      String   @default("✅")
  status      String   @default("active") // active, paused, archived
  socialLinks String   @default("[]") // JSON array
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  archivedAt  DateTime?

  campaigns      Campaign[]
  marketingTasks MarketingTask[]
  creativeRequests CreativeRequest[]
  productionJobs ProductionJob[]
  publishingItems PublishingItem[]
  assets         Asset[]
  userClients    UserClient[]
  activities     ActivityLog[]

  // New module relations
  invoices          Invoice[]
  portalAccess      ClientPortalAccess[]
  clientFeedback    ClientFeedback[]
  contactLogs       ContactLog[]
  leadScore         LeadScore?

  @@index([status])
}

model Campaign {
  id          String   @id @default(cuid())
  clientId    String
  name        String
  nameAr      String   @default("")
  description String   @default("")
  status      String   @default("planning") // planning, active, paused, completed, archived
  startDate   DateTime?
  endDate     DateTime?
  budget      String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client         Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  marketingTasks MarketingTask[]
  creativeRequests CreativeRequest[]
  productionJobs ProductionJob[]
  publishingItems PublishingItem[]

  @@index([clientId])
  @@index([status])
}

model MarketingTask {
  id          String   @id @default(cuid())
  clientId    String
  campaignId  String?
  title       String
  titleAr     String   @default("")
  description String   @default("")
  status      String   @default("pending") // pending, in_progress, review, approved, completed
  priority    String   @default("medium")
  assignedTo  String   @default("")
  assigneeId  String?
  platform    String   @default("")
  contentType String   @default("")
  dueDate     DateTime?
  completedAt DateTime?
  // Cross-board sync
  linkedCreativeRequestId String?
  syncStatus  String   @default("none") // none, pending, synced, failed
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id])
  assignee User?     @relation("MarketingAssignee", fields: [assigneeId], references: [id])

  @@index([clientId])
  @@index([campaignId])
  @@index([status])
  @@index([assigneeId])
  @@index([dueDate])
}

model CreativeRequest {
  id           String   @id @default(cuid())
  clientId     String
  campaignId   String?
  title        String
  titleAr      String   @default("")
  category     String   @default("social_post")
  brief        String   @default("")
  status       String   @default("new_request")
  priority     String   @default("medium")
  assignedTo   String   @default("")
  conceptWriterId String?
  executorId   String?
  platform     String   @default("")
  format       String   @default("")
  dueDate      DateTime?
  reviewRound  Int      @default(0)
  conceptApproved Boolean @default(false)
  finalApproved Boolean  @default(false)
  blocked      Boolean  @default(false)
  blockReason  String   @default("")
  // Cross-board sync
  linkedMarketingTaskId  String?
  linkedProductionJobId  String?
  syncStatus   String   @default("none") // none, pending, synced, failed
  lastSyncedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign      Campaign? @relation(fields: [campaignId], references: [id])
  conceptWriter User?     @relation("CreativeConceptWriter", fields: [conceptWriterId], references: [id])
  executor      User?     @relation("CreativeExecutor", fields: [executorId], references: [id])

  @@index([clientId])
  @@index([campaignId])
  @@index([status])
  @@index([conceptWriterId])
  @@index([executorId])
  @@index([dueDate])
}

model ProductionJob {
  id          String   @id @default(cuid())
  clientId    String
  campaignId  String?
  title       String
  titleAr     String   @default("")
  jobType     String   @default("video") // video, photo, motion, audio
  status      String   @default("pending")
  priority    String   @default("medium")
  assignedTo  String   @default("")
  assigneeId  String?
  shootDate   DateTime?
  dueDate     DateTime?
  location    String   @default("")
  equipment   String   @default("[]") // JSON
  deliverables String  @default("[]") // JSON
  // Cross-board sync
  linkedCreativeRequestId String?
  syncStatus  String   @default("none")
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id])
  assignee User?     @relation("ProductionAssignee", fields: [assigneeId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([assigneeId])
  @@index([dueDate])
}

model PublishingItem {
  id          String   @id @default(cuid())
  clientId    String
  campaignId  String?
  title       String
  titleAr     String   @default("")
  platform    String   @default("")
  status      String   @default("draft") // draft, scheduled, published, archived
  scheduledAt DateTime?
  publishedAt DateTime?
  content     String   @default("")
  mediaUrls   String   @default("[]") // JSON
  reviewerId  String?
  // Cross-board sync
  linkedProductionJobId String?
  linkedCreativeRequestId String?
  syncStatus  String   @default("none")
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id])
  reviewer User?     @relation("PublishingReviewer", fields: [reviewerId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([reviewerId])
  @@index([scheduledAt])
}

// ═══════════════════════════════════════════════════════════════
// ASSETS & COLLABORATION LAYER
// ═══════════════════════════════════════════════════════════════

model Asset {
  id          String   @id @default(cuid())
  clientId    String?
  name        String
  category    String   @default("general") // logo, brand_guide, visual_ref, template, font, general
  fileUrl     String   @default("")
  fileType    String   @default("")
  fileSize    Int      @default(0)
  description String   @default("")
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([category])
}

model Comment {
  id          String   @id @default(cuid())
  entityType  String   // creative_request, production_job, marketing_task, publishing_item
  entityId    String
  userId      String
  text        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
}

model Approval {
  id          String   @id @default(cuid())
  entityType  String   // creative_concept, creative_final, production_review, publishing
  entityId    String
  userId      String
  decision    String   // approved, rejected, revision_requested
  notes       String   @default("")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // approval, deadline, mention, report, system
  title     String
  titleAr   String   @default("")
  message   String   @default("")
  messageAr String   @default("")
  isRead    Boolean  @default(false)
  entityType String  @default("")
  entityId  String   @default("")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  clientId   String?
  entityType String   @default("")
  entityId   String   @default("")
  action     String   // created, updated, deleted, approved, rejected, assigned, status_changed
  details    String   @default("") // JSON
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  @@index([userId])
  @@index([clientId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // settings_changed, role_assigned, user_created, permission_updated
  category  String   @default("system") // system, user, role, department, settings, security
  details   String   @default("{}") // JSON with before/after
  ipAddress String   @default("")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([category])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// CHAT & MESSAGING LAYER
// ═══════════════════════════════════════════════════════════════

model ChatRoom {
  id           String   @id @default(cuid())
  name         String
  nameAr       String   @default("")
  type         String   @default("department") // company, department, client, direct, project
  departmentId String?
  clientId     String?
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages     ChatMessage[]
  members      ChatRoomMember[]

  @@index([type])
}

model ChatRoomMember {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  role      String   @default("member") // admin, member
  joinedAt  DateTime @default(now())
  lastReadAt DateTime?

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String
  content   String
  type      String   @default("text") // text, system, ai_suggestion, card_reference
  mentions  String   @default("[]") // JSON array of user IDs
  replyToId String?
  entityType String  @default("") // creative_request, production_job, etc.
  entityId  String   @default("")
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room    ChatRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender  User         @relation("ChatMessageSender", fields: [senderId], references: [id])
  replyTo ChatMessage? @relation("ChatReplies", fields: [replyToId], references: [id])
  replies ChatMessage[] @relation("ChatReplies")

  @@index([roomId, createdAt])
  @@index([senderId])
}

// ═══════════════════════════════════════════════════════════════
// FINANCIAL LAYER
// ═══════════════════════════════════════════════════════════════

model Invoice {
  id          String   @id @default(cuid())
  number      String   @unique // INV-2026-001
  clientId    String
  campaignId  String?
  status      String   @default("draft") // draft, sent, viewed, paid, overdue, cancelled
  issueDate   DateTime @default(now())
  dueDate     DateTime
  subtotal    Float    @default(0)
  taxRate     Float    @default(0)
  taxAmount   Float    @default(0)
  discount    Float    @default(0)
  total       Float    @default(0)
  currency    String   @default("USD")
  notes       String   @default("")
  notesAr     String   @default("")
  paidAt      DateTime?
  sentAt      DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  descriptionAr String @default("")
  quantity    Float  @default(1)
  rate        Float  @default(0)
  amount      Float  @default(0)
  sortOrder   Int    @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Float
  method      String   @default("bank_transfer") // bank_transfer, cash, card, cheque, other
  reference   String   @default("")
  notes       String   @default("")
  paidAt      DateTime @default(now())
  recordedBy  String?
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Expense {
  id          String   @id @default(cuid())
  category    String   // salaries, software, equipment, travel, marketing, office, freelancer, other
  description String
  descriptionAr String @default("")
  amount      Float
  currency    String   @default("USD")
  date        DateTime @default(now())
  receiptUrl  String   @default("")
  clientId    String?
  campaignId  String?
  status      String   @default("pending") // pending, approved, rejected
  approvedBy  String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([date])
}

model Budget {
  id          String   @id @default(cuid())
  clientId    String?
  campaignId  String?
  name        String
  nameAr      String   @default("")
  allocated   Float    @default(0)
  spent       Float    @default(0)
  period      String   @default("monthly") // monthly, quarterly, yearly, project
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("active") // active, closed, exceeded
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([campaignId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// TIME TRACKING LAYER
// ═══════════════════════════════════════════════════════════════

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  clientId    String?
  taskType    String   @default("") // marketing_task, creative_request, production_job, publishing_item, general
  taskId      String   @default("")
  description String   @default("")
  descriptionAr String @default("")
  startTime   DateTime
  endTime     DateTime?
  duration    Int      @default(0) // in minutes
  billable    Boolean  @default(true)
  rate        Float    @default(0)
  status      String   @default("running") // running, completed, edited
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation("TimeEntries", fields: [userId], references: [id])

  @@index([userId])
  @@index([clientId])
  @@index([startTime])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// FILE MANAGEMENT LAYER
// ═══════════════════════════════════════════════════════════════

model FileAttachment {
  id          String   @id @default(cuid())
  entityType  String   @default("") // creative_request, production_job, invoice, client, general
  entityId    String   @default("")
  fileName    String
  fileUrl     String
  fileSize    Int      @default(0) // bytes
  mimeType    String   @default("")
  folder      String   @default("general") // general, brand_assets, deliverables, documents, receipts
  uploadedBy  String?
  description String   @default("")
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([folder])
  @@index([uploadedBy])
}

// ═══════════════════════════════════════════════════════════════
// PROJECT TIMELINE & MILESTONES
// ═══════════════════════════════════════════════════════════════

model ProjectMilestone {
  id          String   @id @default(cuid())
  campaignId  String?
  clientId    String?
  title       String
  titleAr     String   @default("")
  description String   @default("")
  dueDate     DateTime
  completedAt DateTime?
  status      String   @default("pending") // pending, in_progress, completed, overdue
  color       String   @default("#6366f1")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model TaskDependency {
  id              String @id @default(cuid())
  taskType        String // marketing_task, creative_request, production_job, publishing_item
  taskId          String
  dependsOnType   String
  dependsOnId     String
  dependencyType  String @default("finish_to_start") // finish_to_start, start_to_start, finish_to_finish
  createdAt       DateTime @default(now())

  @@unique([taskType, taskId, dependsOnType, dependsOnId])
  @@index([taskType, taskId])
  @@index([dependsOnType, dependsOnId])
}

// ═══════════════════════════════════════════════════════════════
// CLIENT PORTAL
// ═══════════════════════════════════════════════════════════════

model ClientPortalAccess {
  id          String   @id @default(cuid())
  clientId    String
  email       String
  name        String   @default("")
  tokenHash   String   @default("")
  permissions String   @default("view") // view, approve, comment, files
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, email])
  @@index([email])
}

model ClientFeedback {
  id          String   @id @default(cuid())
  clientId    String
  portalAccessId String?
  entityType  String   // creative_request, production_job, publishing_item, deliverable
  entityId    String
  content     String
  rating      Int?     // 1-5
  status      String   @default("new") // new, acknowledged, resolved
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([entityType, entityId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// HR & RESOURCE MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model LeaveRequest {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("annual") // annual, sick, personal, unpaid, remote
  startDate   DateTime
  endDate     DateTime
  days        Float    @default(1)
  reason      String   @default("")
  status      String   @default("pending") // pending, approved, rejected, cancelled
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation("LeaveRequests", fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate])
}

model PerformanceReview {
  id          String   @id @default(cuid())
  userId      String
  reviewerId  String
  period      String   // Q1-2026, Q2-2026, etc.
  rating      Int      @default(0) // 1-5
  strengths   String   @default("")
  improvements String  @default("")
  goals       String   @default("")
  status      String   @default("draft") // draft, submitted, acknowledged
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User @relation("PerformanceReviews", fields: [userId], references: [id])
  reviewer User @relation("ReviewsConducted", fields: [reviewerId], references: [id])

  @@index([userId])
  @@index([reviewerId])
  @@index([period])
}

// ═══════════════════════════════════════════════════════════════
// KNOWLEDGE BASE / WIKI
// ═══════════════════════════════════════════════════════════════

model WikiArticle {
  id          String   @id @default(cuid())
  title       String
  titleAr     String   @default("")
  slug        String   @unique
  content     String   @default("")
  contentAr   String   @default("")
  category    String   @default("general") // general, process, template, onboarding, policy
  tags        String   @default("[]") // JSON array
  authorId    String
  isPublished Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation("WikiArticles", fields: [authorId], references: [id])

  @@index([category])
  @@index([slug])
  @@index([authorId])
}

// ═══════════════════════════════════════════════════════════════
// CRM ENHANCEMENTS
// ═══════════════════════════════════════════════════════════════

model ContactLog {
  id          String   @id @default(cuid())
  clientId    String
  userId      String
  type        String   @default("call") // call, email, meeting, whatsapp, visit, note
  subject     String   @default("")
  subjectAr   String   @default("")
  notes       String   @default("")
  outcome     String   @default("") // positive, neutral, negative, follow_up_needed
  followUpDate DateTime?
  duration    Int?     // minutes
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation("ContactLogs", fields: [userId], references: [id])

  @@index([clientId])
  @@index([userId])
  @@index([followUpDate])
}

model LeadScore {
  id          String   @id @default(cuid())
  clientId    String   @unique
  score       Int      @default(0) // 0-100
  engagement  Int      @default(0)
  budget      Int      @default(0)
  urgency     Int      @default(0)
  fit         Int      @default(0)
  lastCalculated DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// CALENDAR & SCHEDULING
// ═══════════════════════════════════════════════════════════════

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  titleAr     String   @default("")
  description String   @default("")
  type        String   @default("meeting") // meeting, deadline, shoot, review, reminder, holiday
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean  @default(false)
  location    String   @default("")
  color       String   @default("#6366f1")
  clientId    String?
  campaignId  String?
  createdBy   String
  isRecurring Boolean  @default(false)
  recurRule   String   @default("") // RRULE format
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator  User @relation("CalendarEvents", fields: [createdBy], references: [id])
  attendees CalendarAttendee[]

  @@index([startAt])
  @@index([createdBy])
  @@index([clientId])
}

model CalendarAttendee {
  id        String @id @default(cuid())
  eventId   String
  userId    String
  status    String @default("pending") // pending, accepted, declined, tentative

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation("CalendarAttendees", fields: [userId], references: [id])

  @@unique([eventId, userId])
}
