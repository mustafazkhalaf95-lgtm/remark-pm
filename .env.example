# ─── Remark PM Environment Variables ───
# Copy this file to .env and fill in your values

# Database connection (SQLite for development)
DATABASE_URL=file:./dev.db

# NextAuth.js — Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# Application URL
NEXTAUTH_URL=http://localhost:3000

# Default password for seeded users (change on first login)
DEFAULT_PASSWORD=changeme-on-first-login
